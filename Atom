        "    # Thermal Interaction (The \"Leak\")\n",
        "    prob = thermal_depolarizing_channel(T)\n",
        "    qml.DepolarizingChannel(prob, wires=0)\n",
        "    qml.DepolarizingChannel(prob, wires=1)\n",
        "\n",
        "    return qml.density_matrix(wires=[0, 1])\n",
        "\n",
