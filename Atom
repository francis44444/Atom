        "# Switching to 'default.mixed' to support noise channels\n",
        "dev_mixed = qml.device(\"default.mixed\", wires=4)\n",
        "\n",
        "def run_noisy_audit(noise_probability=0.1):\n",
        "    @qml.qnode(dev_mixed)\n",
        "    def get_noisy_state():\n",
        "        # Replicating core state preparation\n",
        "        qml.Hadamard(wires=0)\n",
        "        qml.CNOT(wires=[0, 1])\n",
        "        qml.RY(0.3, wires=2)\n",
        "        qml.RX(0.1, wires=3)\n",
        "\n",
        "        # APPLYING ENVIRONMENTAL NOISE to all layers\n",
        "        for i in range(4):\n",
        "            qml.DepolarizingChannel(noise_probability, wires=i)\n",
        "\n",
        "        return qml.density_matrix(wires=[0, 1, 2, 3])\n",
        "\n",
        "    rho = get_noisy_state()\n",
        "\n",
        "    noisy_audit = []\n",
        "    layers = [([0, 1], \"Nucleus\"), ([2], \"Electron Cloud\"), ([3], \"Vacuum Field\")]\n",
        "\n",
        "    print(f\"--- Noise-Induced Decoherence Audit (p={noise_probability}) ---\")\n",
        "    for wires, name in layers:\n",
        "        # Calculate entropy (S)\n",
        "        entropy = float(qml.math.vn_entropy(rho, indices=wires))\n",
        "        # Calculate purity (P)\n",
        "        rho_sub = qml.math.reduce_dm(rho, indices=wires)\n",
        "        purity = float(np.real(np.trace(np.matmul(rho_sub, rho_sub))))\n",
        "        # Calculate Stability (St = P - S)\n",
        "        stability = purity - entropy\n",
        "        # Stability-to-Purity Ratio\n",
        "        ratio = stability / purity\n",
        "\n",
        "        noisy_audit.append({\"layer\": name, \"ratio\": ratio, \"leak\": 1.0 - ratio})\n",
        "        print(f\"Layer: {name:<15} | S/P Ratio: {ratio:.4f} | Leak: {1.0-ratio:.4f}\")\n",
        "\n",
        "    return noisy_audit\n",
        "\n",
        "# Execute the noisy audit\n",
        "noisy_results = run_noisy_audit(noise_probability=0.05)"
