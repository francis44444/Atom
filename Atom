        "def iterations_to_threshold(layers, threshold=1.95, max_iter=100):\n",
        "    total_p = layers * (12 + 4 + 1)\n",
        "    init_p = np.random.uniform(-np.pi, np.pi, total_p, requires_grad=True)\n",
        "\n",
        "    # We will use a list to track how many steps were taken\n",
        "    step_counter = [0]\n",
        "    convergence_step = max_iter\n",
        "\n",
        "    def cost_fn(p):\n",
        "        @qml.qnode(dev)\n",
        "        def get_dm(params):\n",
        "            universal_entangler_ansatz(params, layers=layers)\n",
        "            return qml.density_matrix(wires=[0, 1])\n",
        "\n",
        "        rho = get_dm(p)\n",
        "        evs = qml.math.eigvalsh(rho)\n",
        "        evs = evs[evs > 1e-15]\n",
        "        ent = -qml.math.sum(evs * qml.math.log2(evs))\n",
        "        return float(2.0 - qml.math.real(ent))\n",
        "\n",
        "    def callback(p):\n",
        "        step_counter[0] += 1\n",
        "        current_entropy = 2.0 - cost_fn(p)\n",
        "        # If we cross the threshold, we could stop, but for L-BFGS-B\n",
        "        # we'll just record the first time it happened.\n",
        "        nonlocal convergence_step\n",
        "        if current_entropy >= threshold and convergence_step == max_iter:\n",
        "            convergence_step = step_counter[0]\n",
        "\n",
        "    scipy.optimize.minimize(\n",
        "        cost_fn, init_p, method='L-BFGS-B',\n",
        "        callback=callback, options={'maxiter': max_iter}\n",
        "    )\n",
        "    return convergence_step\n",
        "\n",
        "# Test range of depths\n",
        "test_depths = [2, 4, 6, 8, 10, 12, 14]\n",
        "steps_needed = []\n",
        "\n",
        "print(f\"--- Analyzing Convergence Scaling (Threshold: 1.95) ---\")\n",
        "for d in test_depths:\n",
        "    steps = iterations_to_threshold(d)\n",
        "    steps_needed.append(steps)\n",
        "    print(f\"Depth {d:02d}: reached threshold in {steps} iterations.\")"
      ]
    },
