        "# @title ⚛️ Quantum Unified Field & Entanglement Audit {display-mode: \"form\"}\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import json\n",
        "import pennylane as qml\n",
        "from IPython.display import HTML\n",
        "from google.colab import output, files\n",
        "\n",
        "# 1. Setup PennyLane Simulation\n",
        "num_qubits = 4\n",
        "dev = qml.device(\"default.qubit\", wires=num_qubits)\n",
        "\n",
        "def run_quantum_sweep():\n",
        "    # Sweep ranges: 20x20 grid\n",
        "    sf_range = np.linspace(1.5, 3.5, 20)\n",
        "    em_range = np.linspace(-2.0, -0.5, 20)\n",
        "\n",
        "    landscape = []\n",
        "    # Fixed baseline coefficients\n",
        "    wf, zpe, cross, flux = 0.7, 0.13, 0.45, 0.25\n",
        "\n",
        "    # Observables for the Hamiltonian\n",
        "    obs = [\n",
        "        qml.PauliZ(0) @ qml.PauliZ(1), # Strong\n",
        "        qml.PauliX(0),                 # Weak\n",
        "        qml.PauliZ(2),                 # EM\n",
        "        qml.Identity(3),               # Vacuum/ZPE\n",
        "        qml.PauliZ(0) @ qml.PauliZ(2), # Cross\n",
        "        qml.PauliY(0) @ qml.PauliY(1)  # Flux\n",
        "    ]\n",
        "\n",
        "    print(\"--- Executing 400-Point Quantum Sweep ---\")\n",
        "    for sf in sf_range:\n",
        "        for em in em_range:\n",
        "            coeffs = [float(sf), wf, float(em), zpe, cross, flux]\n",
        "            H = qml.Hamiltonian(coeffs, obs)\n",
        "\n",
        "            @qml.qnode(dev)\n",
        "            def circuit():\n",
        "                qml.RY(0.5, wires=0)\n",
        "                qml.CNOT(wires=[0, 1])\n",
        "                qml.RZ(0.2, wires=2)\n",
        "                qml.RX(0.1, wires=3)\n",
        "                return qml.expval(H)\n",
        "\n",
        "            energy = float(circuit())\n",
        "            landscape.append({'strong': float(sf), 'em': float(em), 'energy': energy})\n",
        "\n",
        "    return landscape\n",
        "\n",
        "def run_entanglement_audit():\n",
        "    @qml.qnode(dev)\n",
        "    def get_state():\n",
        "        qml.Hadamard(wires=0)\n",
        "        qml.CNOT(wires=[0, 1])\n",
        "        qml.RY(0.3, wires=2)\n",
        "        qml.RX(0.1, wires=3)\n",
        "        return qml.state()\n",
        "\n",
        "    state = get_state()\n",
        "    # Convert state vector to density matrix for math operations\n",
        "    rho = qml.math.dm_from_state_vector(state)\n",
        "\n",
        "    audit = []\n",
        "    layers = [([0, 1], \"Nucleus\"), ([2], \"Electron Cloud\"), ([3], \"Vacuum Field\")]\n",
        "\n",
        "    for wires, name in layers:\n",
        "        # Correct entropy and reduced density matrix calculation\n",
        "        entropy = float(qml.math.vn_entropy(rho, indices=wires))\n",
        "        rho_sub = qml.math.reduce_dm(rho, indices=wires)\n",
        "        purity = float(np.real(np.trace(np.matmul(rho_sub, rho_sub))))\n",
        "        audit.append({\"layer\": name, \"purity\": purity, \"entropy\": entropy})\n",
        "\n",
        "    return audit\n",
        "\n",
        "# Run Data Processing\n",
        "landscape_data = run_quantum_sweep()\n",
        "audit_data = run_entanglement_audit()\n",
        "\n",
        "# 2. Callbacks for Export\n",
        "def export_dashboard_data(dummy=None):\n",
        "    pd.DataFrame(landscape_data).to_csv('quantum_landscape.csv', index=False)\n",
        "    pd.DataFrame(audit_data).to_csv('entanglement_audit.csv', index=False)\n",
        "    files.download('quantum_landscape.csv')\n",
        "    files.download('entanglement_audit.csv')\n",
        "    return \"Files Sent\"\n",
        "\n",
        "output.register_callback('export_csv', export_dashboard_data)\n",
        "\n",
        "def _report_js_error(msg): print(f\"JS Error: {msg}\")\n",
        "output.register_callback('report_js_error', _report_js_error)\n",
        "\n",
        "# 3. HTML/JS UI\n",
        "html_content = r\"\"\"\n",
        "<!DOCTYPE html>\n",
        "<html>\n",
