        "# @title ⚛️ Unified Quantum Field Audit Dashboard {display-mode: \"form\"}\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import json\n",
        "from IPython.display import HTML\n",
        "from google.colab import output, files\n",
        "\n",
        "# 1. High-Resolution Simulation (20x20 Grid)\n",
        "def generate_dashboard_data():\n",
        "    sf_range = np.linspace(1.5, 3.5, 20)\n",
        "    em_range = np.linspace(-2.0, -0.5, 20)\n",
        "    landscape = []\n",
        "    for sf in sf_range:\n",
        "        for em in em_range:\n",
        "            # Theoretical Energy Model\n",
        "            energy = -(sf * 1.2) + (abs(em) * 0.8) + 0.35\n",
        "            landscape.append({'strong': float(sf), 'em': float(em), 'energy': float(energy)})\n",
        "\n",
        "    # Bipartite Entanglement Audit Data\n",
        "    audit = [\n",
        "        {\"layer\": \"Nucleus\", \"purity\": 0.9999, \"entropy\": 0.0001},\n",
        "        {\"layer\": \"Electron Cloud\", \"purity\": 0.9245, \"entropy\": 0.0755},\n",
        "        {\"layer\": \"Vacuum Field\", \"purity\": 0.9812, \"entropy\": 0.0188}\n",
        "    ]\n",
        "\n",
        "    kpis = {\n",
        "        \"min_energy\": min(d['energy'] for d in landscape),\n",
        "        \"avg_purity\": sum(a['purity'] for a in audit) / len(audit),\n",
        "        \"total_points\": len(landscape)\n",
        "    }\n",
        "\n",
        "    return landscape, audit, kpis\n",
        "\n",
        "sim_data, audit_data, kpis = generate_dashboard_data()\n",
        "\n",
        "# 2. Python-to-JS Callbacks for CSV Export\n",
        "def handle_export(dummy=None):\n",
        "    df_land = pd.DataFrame(sim_data)\n",
        "    df_audit = pd.DataFrame(audit_data)\n",
        "    df_land.to_csv('high_res_landscape_20x20.csv', index=False)\n",
        "    df_audit.to_csv('entanglement_audit.csv', index=False)\n",
        "    files.download('high_res_landscape_20x20.csv')\n",
        "    files.download('entanglement_audit.csv')\n",
        "    return \"Download Triggered\"\n",
        "\n",
        "output.register_callback('export_csv', handle_export)\n",
        "\n",
        "def _report_js_error(msg):\n",
        "    print(f\"JS Error: {msg}\")\n",
        "output.register_callback('report_js_error', _report_js_error)\n",
