        "# Run this pip install command in your Colab cell first to get the libraries:\n",
        "!pip install qiskit qiskit-ionq numpy matplotlib\n",
        "\n",
        "import os\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from mpl_toolkits.mplot3d import Axes3D\n",
        "\n",
        "# Qiskit & IonQ imports\n",
        "from qiskit import QuantumCircuit\n",
        "from qiskit_ionq import IonQProvider\n",
        "\n",
        "print(\"=\"*60)\n",
        "print(\"🌌 PART 1: THE ATOM FUZZY BALL (3D PROBABILITY CLOUD)\")\n",
        "print(\"=\"*60)\n",
        "# We simulate the true \"fuzzy\" nature of a 1s atomic orbital\n",
        "# (The probability cloud for both matter and antimatter looks exactly like this)\n",
        "\n",
        "# 1. Generate a massive 3D grid of random points\n",
        "N = 100000\n",
        "x = np.random.randn(N) * 2\n",
        "y = np.random.randn(N) * 2\n",
        "z = np.random.randn(N) * 2\n",
        "\n",
        "# Calculate distance from the nucleus (r)\n",
        "r = np.sqrt(x**2 + y**2 + z**2)\n",
        "\n",
        "# 2. Apply the raw math: Probability density for a 1s orbital decays exponentially\n",
        "probability_density = np.exp(-2 * r)\n",
        "\n",
        "# 3. Use random thresholding to filter points (creating the \"fuzziness\")\n",
        "random_threshold = np.random.rand(N)\n",
        "fuzzy_mask = random_threshold < probability_density\n",
        "\n",
        "x_fuzzy = x[fuzzy_mask]\n",
        "y_fuzzy = y[fuzzy_mask]\n",
        "z_fuzzy = z[fuzzy_mask]\n",
        "\n",
        "# 4. Render the 3D Fuzzy Ball\n",
        "fig = plt.figure(figsize=(8, 8))\n",
        "ax = fig.add_subplot(111, projection='3d')\n",
        "\n",
        "# Color the points based on their distance from the center to look like glowing energy\n",
        "colors = np.linalg.norm([x_fuzzy, y_fuzzy, z_fuzzy], axis=0)\n",
        "ax.scatter(x_fuzzy, y_fuzzy, z_fuzzy, c=colors, cmap='plasma', alpha=0.15, s=10, edgecolors='none')\n",
        "\n",
        "ax.set_title(\"The 'Fuzzy Ball' Atom (Electron/Positron Probability Cloud)\")\n",
        "ax.set_xlabel(\"X (Space)\")\n",
        "ax.set_ylabel(\"Y (Space)\")\n",
        "ax.set_zlabel(\"Z (Space)\")\n",
        "\n",
        "# Hide the grid panes so it looks like it's floating in empty space\n",
        "ax.xaxis.pane.fill = False\n",
        "ax.yaxis.pane.fill = False\n",
