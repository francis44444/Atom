        "        {\"layer\": \"Vacuum Field\", \"purity\": 0.9812, \"entropy\": 0.0188}\n",
        "    ]\n",
        "\n",
        "    kpis = {\n",
        "        \"min_energy\": min(d['energy'] for d in landscape),\n",
        "        \"avg_purity\": sum(a['purity'] for a in audit) / len(audit),\n",
        "        \"total_points\": len(landscape)\n",
        "    }\n",
        "\n",
        "    return landscape, audit, kpis\n",
        "\n",
