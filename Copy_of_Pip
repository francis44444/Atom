        "# 2. Entanglement Audit at the New Global Minimum\n",
        "@qml.qnode(dev)\n",
        "def get_optimal_state(params):\n",
        "    qml.RX(params[0], wires=3)\n",
        "    qml.RY(params[1], wires=0)\n",
        "    qml.RY(params[2], wires=1)\n",
        "    qml.CNOT(wires=[0, 1])\n",
        "    qml.RZ(params[3], wires=2)\n",
        "    qml.CRZ(params[0], wires=[0, 2])\n",
        "    qml.CZ(wires=[1, 2])\n",
        "    return qml.state()\n",
        "\n",
        "state_vec = get_optimal_state(np.array(best_state['params']))\n",
        "rho_nucleus = qml.math.dm_from_state_vector(state_vec)\n",
        "# Measure entropy of the Nucleus (wires 0, 1)\n",
