        " y import numpy as py_np\n",
        "import pennylane as qml\n",
        "from pennylane import numpy as np\n",
        "\n",
        "# 1. Define 3D Search Space\n",
        "# We vary all three primary force parameters\n",
        "sf_range = py_np.linspace(1.5, 3.5, 4)\n",
        "wf_range = py_np.linspace(0.1, 1.5, 4)\n",
        "em_range = py_np.linspace(-2.0, -0.5, 4)\n",
        "\n",
        "results_3d = []\n",
        "\n",
        "print(f\"--- Starting 3D Unified Field Sweep ({len(sf_range)*len(wf_range)*len(em_range)} configurations) ---\")\n",
        "\n",
        "for sf in sf_range:\n",
        "    for wf in wf_range:\n",
        "        for em in em_range:\n",
        "            # Hamiltonian coefficients: [Strong, Weak, EM, Identity, Z0Z2, Y0Y1]\n",
        "            current_coeffs = [float(sf), float(wf), float(em), 0.13, 0.45, 0.25]\n",
        "            current_H = qml.Hamiltonian(current_coeffs, obs)\n",
        "\n",
        "            @qml.qnode(dev)\n",
        "            def sweep_circuit(params):\n",
        "                qml.RX(params[0], wires=3)\n",
        "                qml.RY(params[1], wires=0)\n",
        "                qml.RY(params[2], wires=1)\n",
        "                qml.CNOT(wires=[0, 1])\n",
        "                qml.RZ(params[3], wires=2)\n",
        "                qml.CRZ(params[0], wires=[0, 2])\n",
        "                qml.CZ(wires=[1, 2])\n",
        "                return qml.expval(current_H)\n",
        "\n",
        "            # Quick optimization for each point\n",
        "            p = np.array([0.15, 0.22, 0.38, 0.41], requires_grad=True)\n",
        "            opt = qml.GradientDescentOptimizer(stepsize=0.6)\n",
        "            for _ in range(30):\n",
        "                p = opt.step(sweep_circuit, p)\n",
        "\n",
        "            energy = float(sweep_circuit(p))\n",
        "            results_3d.append({\n",
        "                'strong': sf, 'weak': wf, 'em': em, 'energy': energy, 'params': p.tolist()\n",
        "            })\n",
        "\n",
        "# Find Global Minimum in 3D Space\n",
        "best_state = min(results_3d, key=lambda x: x['energy'])\n",
        "print(f\"\\nGlobal Minimum Found:\")\n",
        "print(f\"Strong: {best_state['strong']:.2f} | Weak: {best_state['weak']:.2f} | EM: {best_state['em']:.2f}\")\n",
        "print(f\"Energy: {best_state['energy']:.6f}\")"
