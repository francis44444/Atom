        "# Redefine the optimization logic to accept custom initial parameters\n",
        "def optimize_with_params(init_params, steps=100, lr=0.6):\n",
        "    params = np.array(init_params, requires_grad=True)\n",
        "    opt = qml.GradientDescentOptimizer(stepsize=lr)\n",
        "    energies = []\n",
        "    for _ in range(steps):\n",
        "        params, energy = opt.step_and_cost(quantum_project_circuit, params)\n",
        "        energies.append(float(energy))\n",
        "    return energies\n",
        "\n",
        "# Baseline parameters\n",
        "base_p = [0.15, 0.22, 0.38, 0.41]\n",
        "\n",
        "# Sensitivity Analysis: 5 different starting points with random noise (+/- 0.2)\n",
        "num_trials = 5\n",
        "trial_results = {}\n",
        "\n",
        "print(\"--- Starting Parameter Sensitivity Test ---\")\n",
        "for i in range(num_trials):\n",
        "    # Perturb the baseline\n",
        "    noise = py_np.random.uniform(-0.2, 0.2, size=4)\n",
        "    p_start = [base_p[j] + noise[j] for j in range(4)]\n",
        "\n",
        "    energies = optimize_with_params(p_start)\n",
        "    trial_results[f\"Trial {i+1}\"] = energies\n",
